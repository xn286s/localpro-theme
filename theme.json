{
    "$schema": "https://schemas.wp.org/wp/6.9/theme.json",
    "version": 3,
    "customTemplates": [
        {
            "name": "single-service",
            "postTypes": [
                "service"
            ],
            "title": "Service"
        },
        {
            "name": "blank",
            "title": "Blank"
        }
    ],
    "settings": {
        "appearanceTools": true,
        "color": {
            "palette": [
                {
                    "name": "Primary",
                    "slug": "primary",
                    "color": "hsl(var(--wp--custom--hue), 50%, 50%)"
                },
                {
                    "name": "Accent",
                    "slug": "accent",
                    "color": "hsl(calc(var(--wp--custom--hue) + 30), 50%, 50%)"
                },
                {
                    "name": "Complimentary",
                    "slug": "complimentary",
                    "color": "hsl(calc(var(--wp--custom--hue) + 180), 50%, 50%)"
                },
                {
                    "name": "Surface",
                    "slug": "surface",
                    "color": "hsl(var(--wp--custom--hue), 5%, 95%)"
                },
                {
                    "name": "Contrast",
                    "slug": "contrast",
                    "color": "hsl(var(--wp--custom--hue), 95%, 5%)"
                },
                {
                    "name": "Tint",
                    "slug": "tint",
                    "color": "hsl(var(--wp--custom--hue), 20%, 75%)"
                },
                {
                    "name": "Mid",
                    "slug": "mid",
                    "color": "hsl(var(--wp--custom--hue), 20%, 50%)"
                },
                {
                    "name": "Shade",
                    "slug": "shade",
                    "color": "hsl(var(--wp--custom--hue), 20%, 25%)"
                }
            ]
        },
        "custom": {
            "hue": "270"
        },
        "layout": {
            "contentSize": "1280px",
            "wideSize": "1280px"
        },
        "shadow": {
            "presets": [
                {
                    "name": "Lifted",
                    "shadow": "0px 0px 8px -4px #000000",
                    "slug": "lifted"
                }
            ]
        },
        "spacing": {
            "blockGap": true
        },
        "typography": {
            "defaultFontSizes": false,
            "fontFamilies": [
                {
                    "fontFamily": "Inter, sans-serif",
                    "name": "Display",
                    "slug": "display",
                    "fontFace": [
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "100...900",
                            "fontStyle": "normal, italic",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/Inter-VariableFont_opsz,wght.ttf"
                            ]
                        }
                    ]
                },
                {
                    "fontFamily": "Montserrat, sans-serif",
                    "name": "Body",
                    "slug": "body",
                    "fontFace": [
                        {
                            "fontFamily": "Montserrat",
                            "fontWeight": "100...900",
                            "fontStyle": "normal, italic",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/Montserrat-VariableFont_wght.ttf"
                            ]
                        }
                    ]
                },
                {
                    "fontFamily": "Material Symbols Outlined",
                    "name": "Icons",
                    "slug": "icons",
                    "fontFace": [
                        {
                            "fontFamily": "Material Symbols Outlined",
                            "fontStyle": "normal",
                            "fontWeight": 400,
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/MaterialSymbolsOutlined[FILL,GRAD,opsz,wght].ttf"
                            ]
                        }
                    ]
                }
            ],
            "fontSizes": [
                {
                    "name": "Small",
                    "slug": "small",
                    "size": "1.2rem"
                },
                {
                    "name": "Base",
                    "slug": "base",
                    "size": "1.6rem"
                },
                {
                    "name": "Label",
                    "slug": "label",
                    "size": "2rem"
                },
                {
                    "name": "Subheading",
                    "size": "clamp(2.4rem, 0.4vw + 2.08rem, 3.2rem)",
                    "slug": "subheading"
                },
                {
                    "name": "Heading",
                    "size": "clamp(3.2rem, 0.4vw + 2.88rem, 4rem)",
                    "slug": "heading"
                },
                {
                    "name": "Title",
                    "size": "clamp(4rem, 1vw + 3.52rem, 4.8rem)",
                    "slug": "title"
                }
            ]
        },
        "useRootPaddingAwareAlignments": true
    },
    "styles": {
        "blocks": {
            "core/buttons": {
                "spacing": {
                    "blockGap": "2rem"
                }
            },
            "core/column": {
                "border": {
                    "radius": {
                        "bottomLeft": "0.8rem",
                        "bottomRight": "0.8rem",
                        "topLeft": "0.8rem",
                        "topRight": "0.8rem"
                    }
                },
                "spacing": {
                    "blockGap": "2rem",
                    "padding": {
                        "bottom": "1rem",
                        "left": "1rem",
                        "right": "1rem",
                        "top": "1rem"
                    }
                }
            },
            "core/columns": {
                "spacing": {
                    "blockGap": "2rem",
                    "padding": {
                        "bottom": "1rem",
                        "left": "1rem",
                        "right": "1rem",
                        "top": "1rem"
                    }
                }
            },
            "core/cover": {
                "spacing": {
                    "blockGap": "2rem",
                    "padding": {
                        "bottom": "clamp(4rem, 4.167vw + 2.667rem, 8rem)",
                        "top": "clamp(4rem, 4.167vw + 2.667rem, 8rem)"
                    }
                }
            },
            "core/group": {
                "spacing": {
                    "blockGap": "2rem",
                    "padding": {
                        "bottom": "clamp(4rem, 4.167vw + 2.667rem, 8rem)",
                        "top": "clamp(4rem, 4.167vw + 2.667rem, 8rem)"
                    }
                }
            },
            "core/heading": {
                "color": {
                    "text": "var(--wp--preset--color--contrast)"
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--display)",
                    "lineHeight": "1"
                }
            },
            "core/list": {
                "css": "width: fit-content",
                "spacing": {
                    "padding": {
                        "left": "2rem"
                    }
                },
                "typography": {
                    "lineHeight": "1"
                }
            },
            "core/navigation": {
                "spacing": {
                    "blockGap": "2.4rem"
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--display)",
                    "textTransform": "uppercase",
                    "letterSpacing": "1px"
                }
            },
            "core/paragraph": {
                "css": "max-width: min(100%, 55ch)"
            },
            "core/post-template": {
                "spacing": {
                    "blockGap": "2rem"
                }
            }
        },
        "color": {
            "background": "var(--wp--preset--color--surface)",
            "text": "var(--wp--preset--color--shade)"
        },
        "elements": {
            "button": {
                ":hover": {
                    "border": {
                        "color": "var(--wp--preset--color--primary)"
                    },
                    "color": {
                        "background": "var(--wp--preset--color--surface)",
                        "text": "var(--wp--preset--color--primary)"
                    }
                },
                "border": {
                    "color": "var(--wp--preset--color--primary)",
                    "radius": "128px",
                    "style": "solid",
                    "width": "1px"
                },
                "color": {
                    "background": "var(--wp--preset--color--primary)",
                    "text": "var(--wp--preset--color--surface)"
                },
                "css": "transition: border-color 300ms ease, color 300ms ease, background-color 300ms ease",
                "shadow": "0 0 8px -4px #000000",
                "spacing": {
                    "padding": {
                        "bottom": "1.2rem",
                        "left": "2.4rem",
                        "right": "2.4rem",
                        "top": "1.2rem"
                    }
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--display)",
                    "fontSize": "var(--wp--preset--font-size--label)",
                    "textTransform": "uppercase",
                    "letterSpacing": "1px"
                }
            },
            "h1": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--title)"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--heading)"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--subheading)"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--label)"
                }
            },
            "h5": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--label)"
                }
            },
            "h6": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--label)"
                }
            }
        },
        "spacing": {
            "blockGap": "0px"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--body)",
            "fontSize": "var(--wp--preset--font-size--base)",
            "fontWeight": "400",
            "lineHeight": "1.6"
        }
    },
    "templateParts": [
        {
            "area": "header",
            "name": "header",
            "title": "Header"
        },
        {
            "area": "footer",
            "name": "footer",
            "title": "Footer"
        },
        {
            "area": "uncategorized",
            "name": "button-primary",
            "title": "Primary Button"
        },
        {
            "area": "uncategorized",
            "name": "button-secondary",
            "title": "Secondary Button"
        }
    ]
}