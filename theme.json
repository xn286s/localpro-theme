{
    "$schema": "https://schemas.wp.org/wp/6.9/theme.json",
    "version": 3,
    "customTemplates": [
        {
            "name": "single-service",
            "postTypes": [
                "service"
            ],
            "title": "Service"
        },
        {
            "name": "blank",
            "title": "Blank"
        }
    ],
    "settings": {
        "appearanceTools": true,
        "color": {
            "palette": [
                {
                    "name": "Primary",
                    "slug": "primary",
                    "color": "hsl(var(--wp--custom--hue), 70%, 50%)"
                },
                {
                    "name": "Accent",
                    "slug": "accent",
                    "color": "hsl(calc(var(--wp--custom--hue) + 30), 70%, 50%)"
                },
                {
                    "name": "Complimentary",
                    "slug": "complimentary",
                    "color": "hsl(calc(var(--wp--custom--hue) + 180), 70%, 50%)"
                },
                {
                    "name": "Surface",
                    "slug": "surface",
                    "color": "hsl(var(--wp--custom--hue), 50%, 95%)"
                },
                {
                    "name": "Contrast",
                    "slug": "contrast",
                    "color": "hsl(var(--wp--custom--hue), 100%, 5%)"
                },
                {
                    "name": "Tint",
                    "slug": "tint",
                    "color": "hsl(var(--wp--custom--hue), 20%, 80%)"
                },
                {
                    "name": "Mid",
                    "slug": "mid",
                    "color": "hsl(var(--wp--custom--hue), 20%, 50%)"
                },
                {
                    "name": "Shade",
                    "slug": "shade",
                    "color": "hsl(var(--wp--custom--hue), 20%, 20%)"
                }
            ]
        },
        "custom": {
            "--hue": "0"
        },
        "layout": {
            "contentSize": "1280px",
            "wideSize": "1280px"
        },
        "shadow": {
            "presets": [
                {
                    "name": "Lifted",
                    "shadow": "0px 0px 12px -4px #000000",
                    "slug": "lifted"
                }
            ]
        },
        "spacing": {
            "blockGap": true
        },
        "typography": {
            "defaultFontSizes": false,
            "fontFamilies": [
                {
                    "fontFamily": "Inter, sans-serif",
                    "name": "Display",
                    "slug": "display"
                },
                {
                    "fontFamily": "Montserrat, sans-serif",
                    "name": "Body",
                    "slug": "body"
                }
            ],
            "fontSizes": [
                {
                    "name": "Small",
                    "slug": "small",
                    "size": "0.8rem"
                },
                {
                    "name": "Base",
                    "slug": "base",
                    "size": "1rem"
                },
                {
                    "name": "Label",
                    "slug": "label",
                    "size": "clamp(1.125rem, 0.208vw + 1.083rem, 1.25rem)"
                },
                {
                    "name": "Subheading",
                    "slug": "subheading",
                    "size": "clamp(1.25rem, 0.417vw + 1.167rem, 1.5rem)"
                },
                {
                    "name": "Heading",
                    "slug": "heading",
                    "size": "clamp(1.75rem, 0.417vw + 1.667rem, 2rem)"
                },
                {
                    "name": "Title",
                    "slug": "title",
                    "size": "clamp(2.5rem, 0.833vw + 2.333rem, 3rem)"
                }
            ]
        },
        "useRootPaddingAwareAlignments": true
    },
    "styles": {
        "blocks": {
            "core/buttons": {
                "spacing": {
                    "blockGap": "1.25rem"
                }
            },
            "core/column": {
                "border": {
                    "radius": {
                        "bottomLeft": "0.5rem",
                        "bottomRight": "0.5rem",
                        "topLeft": "0.5rem",
                        "topRight": "0.5rem"
                    }
                },
                "spacing": {
                    "blockGap": "1.25rem",
                    "padding": {
                        "bottom": "0.5rem",
                        "left": "0.5rem",
                        "right": "0.5rem",
                        "top": "0.5rem"
                    }
                }
            },
            "core/columns": {
                "spacing": {
                    "blockGap": "1.25rem",
                    "padding": {
                        "bottom": "0.5rem",
                        "left": "0.5rem",
                        "right": "0.5rem",
                        "top": "0.5rem"
                    }
                }
            },
            "core/cover": {
                "spacing": {
                    "blockGap": "1.25rem",
                    "padding": {
                        "bottom": "clamp(3rem, 3.333vw + 2.333rem, 5rem)",
                        "top": "clamp(3rem, 3.333vw + 2.333rem, 5rem)"
                    }
                }
            },
            "core/group": {
                "spacing": {
                    "blockGap": "1.25rem",
                    "padding": {
                        "bottom": "clamp(3rem, 3.333vw + 2.333rem, 5rem)",
                        "top": "clamp(3rem, 3.333vw + 2.333rem, 5rem)"
                    }
                }
            },
            "core/heading": {
                "elements": {
                    "h1": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--title)"
                        }
                    },
                    "h2": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--heading)"
                        }
                    },
                    "h3": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--subheading)"
                        }
                    },
                    "h4": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--label)"
                        }
                    },
                    "h5": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--label)"
                        }
                    },
                    "h6": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--label)"
                        }
                    }
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--display)",
                    "lineHeight": "1"
                }
            },
            "core/list": {
                "spacing": {
                    "padding": {
                        "left": "2rem"
                    }
                },
                "css": "width: fit-content"
            },
            "core/navigation": {
                "spacing": {
                    "blockGap": "1.5rem"
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--display)",
                    "textTransform": "uppercase",
                    "letterSpacing": "1px"
                }
            },
            "core/paragraph": {
                "css": "width: min(100%, 55ch)"
            },
            "core/post-template": {
                "spacing": {
                    "blockGap": "1.25rem"
                }
            }
        },
        "color": {
            "background": "var(--wp--preset--color--surface)",
            "text": "var(--wp--preset--color--shade)"
        },
        "elements": {
            "button": {
                ":hover": {
                    "border": {
                        "color": "var(--wp--preset--color--primary)"
                    },
                    "color": {
                        "background": "var(--wp--preset--color--surface)",
                        "text": "var(--wp--preset--color--primary)"
                    }
                },
                "border": {
                    "color": "var(--wp--preset--color--primary)",
                    "radius": "128px",
                    "style": "solid",
                    "width": "1px"
                },
                "color": {
                    "background": "var(--wp--preset--color--primary)",
                    "text": "var(--wp--preset--color--surface)"
                },
                "css": "transition: all 0.3s ease",
                "shadow": "0 0 8px -4px #000000",
                "spacing": {
                    "padding": {
                        "bottom": "0.75rem",
                        "left": "1.5rem",
                        "right": "1.5rem",
                        "top": "0.75rem"
                    }
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--display)",
                    "fontSize": "var(--wp--preset--font-size--label)",
                    "textTransform": "uppercase",
                    "letterSpacing": "1px"
                }
            },
            "heading": {
                "color": {
                    "text": "var(--wp--preset--color--contrast)"
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--display)",
                    "lineHeight": "1"
                },
                "css": "width: min(100%, 55ch)"
            }
        },
        "spacing": {
            "blockGap": "0px"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--body)",
            "fontSize": "var(--wp--preset--font-size--base)",
            "fontWeight": "400",
            "lineHeight": "1.6"
        }
    },
    "templateParts": [
        {
            "area": "header",
            "name": "header",
            "title": "Header"
        },
        {
            "area": "footer",
            "name": "footer",
            "title": "Footer"
        },
        {
            "area": "uncategorized",
            "name": "button-primary",
            "title": "Primary Button"
        },
        {
            "area": "uncategorized",
            "name": "button-secondary",
            "title": "Secondary Button"
        }
    ]
}